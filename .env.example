# ─── Neynar ──────────────────────────────────────────────────────────────────
# API key from dev.neynar.com
NEYNAR_API_KEY=

# UUID of the managed signer for the bot account (from dev.neynar.com/app)
BOT_SIGNER_UUID=

# Farcaster ID of the bot account
BOT_FID=

# Webhook secret for verifying Neynar payloads (from dev.neynar.com/webhook)
WEBHOOK_SECRET=

# ─── Anthropic ────────────────────────────────────────────────────────────────
# API key from console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host:5432/higher_athletics

# ─── Chain ────────────────────────────────────────────────────────────────────
# RPC endpoint for Base mainnet (Alchemy/Infura/Coinbase recommended over public)
BASE_RPC_URL=https://mainnet.base.org

# RPC endpoint for Base Sepolia (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key of the agent hot wallet — must hold AGENT_ROLE on the contract
# Use a dedicated wallet; never reuse your deployer key here
AGENT_PRIVATE_KEY=

# Deployed address of HigherCommitmentPool
CONTRACT_ADDRESS=

# $HIGHER ERC-20 on Base mainnet
HIGHER_TOKEN_ADDRESS=0x0578d8A44db98B23BF096A382e016e29a5Ce0ffe

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Contract deployment (dev / CI only — not required at runtime) ────────────
# Chain ID: 8453 = Base mainnet (default), 84532 = Base Sepolia
CHAIN_ID=8453

# Deployer wallet — only needed for deploy/seed/update-agent scripts
DEPLOYER_PRIVATE_KEY=

# Address that receives 10% protocol fees (defaults to deployer if unset)
FEE_RECIPIENT=

# Agent wallet public address — used by deploy.ts to set AGENT_ROLE
# If unset, derived automatically from AGENT_PRIVATE_KEY
AGENT_ADDRESS=

# Basescan API key for contract verification
BASESCAN_API_KEY=
